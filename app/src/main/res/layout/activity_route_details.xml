<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="Детали маршрута"
            app:titleTextColor="@color/white"
            app:navigationIcon="?attr/homeAsUpIndicator" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_small">

                        <TextView
                            android:id="@+id/routeName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/routeStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="@dimen/spacing_small"
                            android:paddingEnd="@dimen/spacing_small"
                            android:paddingTop="@dimen/spacing_tiny"
                            android:paddingBottom="@dimen/spacing_tiny"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            android:layout_marginStart="@dimen/spacing_small" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/routeUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autoLink="web"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_small"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:ellipsize="end"
                        android:maxLines="2" />

                    <TextView
                        android:id="@+id/routeCreationDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_small"
                        android:textColor="@color/text_hint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️ Параметры мониторинга"
                        android:textSize="@dimen/text_size_medium"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_small" />

                    <TextView
                        android:id="@+id/routeParameters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_normal"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎮 Управление"
                        android:textSize="@dimen/text_size_medium"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_small" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="@dimen/spacing_small">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonStart"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_small"
                            android:text="▶ Запустить"
                            android:textSize="@dimen/text_size_normal"
                            android:textAllCaps="false"
                            app:cornerRadius="@dimen/button_corner_radius"
                            app:backgroundTint="@color/success" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonStop"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_small"
                            android:text="⏸ Остановить"
                            android:textSize="@dimen/text_size_normal"
                            android:textAllCaps="false"
                            app:cornerRadius="@dimen/button_corner_radius"
                            app:backgroundTint="@color/warning" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonEdit"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_small"
                            android:text="✏️ Изменить"
                            android:textSize="@dimen/text_size_normal"
                            android:textAllCaps="false"
                            app:cornerRadius="@dimen/button_corner_radius"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="2dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonDelete"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_small"
                            android:text="🗑 Удалить"
                            android:textSize="@dimen/text_size_normal"
                            android:textAllCaps="false"
                            app:cornerRadius="@dimen/button_corner_radius"
                            app:strokeColor="@color/error"
                            app:strokeWidth="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Логи мониторинга"
                        android:textSize="@dimen/text_size_medium"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/spacing_small" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_small"
                        android:hint="Поиск по логам за 24 часа"
                        app:endIconMode="clear_text">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editLogSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:textSize="@dimen/text_size_normal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Сортировка"
                        android:textSize="@dimen/text_size_small"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_tiny" />

                    <RadioGroup
                        android:id="@+id/radioLogSortGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_small">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioLogsNewestFirst"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:checked="true"
                            android:text="Новые сверху"
                            android:textSize="@dimen/text_size_small" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioLogsOldestFirst"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Старые сверху"
                            android:textSize="@dimen/text_size_small" />
                    </RadioGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="@dimen/spacing_small">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkLogInfo"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="Инфо"
                                android:gravity="center_vertical"
                                android:minHeight="32dp"
                                android:minWidth="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="@dimen/spacing_small"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:textSize="@dimen/text_size_small" />

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkLogSuccess"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="Успех"
                                android:gravity="center_vertical"
                                android:minHeight="32dp"
                                android:minWidth="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="@dimen/spacing_small"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:textSize="@dimen/text_size_small" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkLogWarning"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="Предупреждения"
                                android:gravity="center_vertical"
                                android:minHeight="32dp"
                                android:minWidth="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="@dimen/spacing_small"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:textSize="@dimen/text_size_small" />

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkLogError"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:checked="true"
                                android:text="Ошибки"
                                android:gravity="center_vertical"
                                android:minHeight="32dp"
                                android:minWidth="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="@dimen/spacing_small"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:textSize="@dimen/text_size_small" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Категории"
                        android:textSize="@dimen/text_size_small"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_tiny" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:layout_marginBottom="@dimen/spacing_small">

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/checkLogMonitoring"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            android:checked="true"
                            android:text="Мониторинг"
                            android:minHeight="32dp"
                            android:minWidth="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="@dimen/spacing_small"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textSize="@dimen/text_size_small" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/checkLogAvailability"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            android:checked="true"
                            android:text="Места"
                            android:minHeight="32dp"
                            android:minWidth="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="@dimen/spacing_small"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textSize="@dimen/text_size_small" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/checkLogAutoPurchase"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            android:checked="true"
                            android:text="Авторезерв"
                            android:minHeight="32dp"
                            android:minWidth="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="@dimen/spacing_small"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textSize="@dimen/text_size_small" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/checkLogTelegram"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            android:checked="true"
                            android:text="Telegram"
                            android:minHeight="32dp"
                            android:minWidth="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="@dimen/spacing_small"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textSize="@dimen/text_size_small" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/checkLogSystem"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="fill_horizontal"
                            android:checked="true"
                            android:text="Система"
                            android:minHeight="32dp"
                            android:minWidth="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="@dimen/spacing_small"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:textSize="@dimen/text_size_small" />
                    </GridLayout>

                    <androidx.core.widget.NestedScrollView
                        android:id="@+id/logScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="320dp"
                        android:background="#F5F5F5"
                        android:padding="@dimen/spacing_small">

                        <TextView
                            android:id="@+id/logTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="2dp" />
                    </androidx.core.widget.NestedScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
